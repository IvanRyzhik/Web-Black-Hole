{
  "name": "black-hole",
  "version": "0.1.0",
  "description": "Play a black hole game on any webpage — consume page content and grow.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "package": "npm run build && node scripts/package-extension.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "chrome-extension",
    "game",
    "three.js",
    "matter-js"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "html2canvas": "^1.4.1",
    "matter-js": "^0.20.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.43",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@webext-core/fake-browser": "^1.5.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
